      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME": "dmp6du0th",
        "EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET": "fault_reports"
